{
  "name": "gravitydesk",
  "version": "1.0.0",
  "description": "Modern AI Desktop Dashboard and Chat for Antigravity CLI",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "electron:dev": "cross-env ELECTRON=true vite",
    "electron:build": "vue-tsc && cross-env ELECTRON=true vite build && electron-builder"
  },
  "build": {
    "appId": "com.xelvor.gravitydesk",
    "productName": "GravityDesk",
    "directories": {
      "output": "out"
    },
    "win": {
      "icon": "electron/resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GravityDesk"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.3.0",
    "dompurify": "^3.1.6",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^0.446.0",
    "marked": "^14.1.2",
    "marked-highlight": "^2.2.4",
    "node-pty": "^1.1.0-beta4",
    "pinia": "^2.2.2",
    "sql.js": "^1.14.1",
    "vue": "^3.5.10"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.16.5",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.12",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^2.1.6"
  }
}
